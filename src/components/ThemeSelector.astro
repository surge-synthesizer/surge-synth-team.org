<select
    aria-label="Theme"
    name="themes"
    id="theme-select"
    class="cursor-pointer rounded border border-white/20 bg-black px-2 py-1 font-semibold text-white transition-colors outline-none hover:bg-white hover:text-black dark:bg-neutral-900">
    <option value="auto">System</option>
    <option value="dark">Dark</option>
    <option value="light">Light</option>
</select>
