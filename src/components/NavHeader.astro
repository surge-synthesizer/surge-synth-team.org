---
import ProjectSelector from "./ProjectSelector.astro";
import ThemeSelector from "./ThemeSelector.astro";
import { getCollection } from "astro:content";

interface Props {
    links?: ReadonlyArray<readonly [title: string, href: string]>;
    currentProject?: string | null;
}

const { links = [], currentProject = null } = Astro.props;

const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
const currentProjectData = projects.find((p) => p.id === currentProject);
---

<nav
    id="nav"
    class="sticky top-0 z-50 bg-black font-semibold text-white shadow-xl backdrop-blur-lg select-none dark:bg-neutral-900 print:hidden">
    <div class="flex items-center gap-3 px-3 py-2">
        <a href="/" title="surge-synth-team.org" class="shrink-0">
            <img
                src="/images/sst-logo.svg"
                alt="Surge Synth Team logo"
                loading="lazy"
                decoding="async"
                width="24"
                height="24"
                class="m-0 min-h-[24px] min-w-[24px] p-0"
            />
        </a>

        <div class="hidden md:flex md:flex-1 md:items-center md:gap-3">
            <menu class="flex shrink-0 items-center">
                <ProjectSelector currentProject={currentProject} />
            </menu>

            {links.length > 0 && (
                <>
                    <div class="h-5 w-px shrink-0 bg-white/20" />
                    <menu class="flex shrink-0 flex-row items-center gap-2">
                        {currentProjectData && (
                            <li>
                                <a href={`/${currentProject}`} class="rounded px-2 py-1 font-bold whitespace-nowrap text-white transition-colors">
                                    {currentProjectData.data.title}
                                </a>
                            </li>
                        )}
                        {links.map(([title, href]) => (
                            <li>
                                <a class="rounded px-2 py-1 whitespace-nowrap text-white transition-colors" href={href}>
                                    {title}
                                </a>
                            </li>
                        ))}
                    </menu>
                </>
            )}
        </div>

        <div class="ml-auto flex shrink-0 items-center gap-3">
            <div class="h-5 w-px bg-white/20"></div>
            <ThemeSelector />
            <button
                id="nav-hamburger"
                class="flex flex-col gap-1 rounded p-1 md:hidden"
                aria-label="Toggle menu">
                <span class="block h-0.5 w-5 bg-white"></span>
                <span class="block h-0.5 w-5 bg-white"></span>
                <span class="block h-0.5 w-5 bg-white"></span>
            </button>
        </div>
    </div>

    <!-- Mobile menu -->
    <div
        id="nav-mobile-menu"
        class="hidden flex-col gap-1 border-t border-white/10 px-3 py-2 md:hidden">

        <!-- Projects section -->
        <div class="flex flex-col">
            <button id="mobile-projects-toggle" class="flex items-center justify-between rounded px-2 py-1 text-white transition-colors hover:bg-white/10">
                <span>Projects</span>
                <span id="mobile-projects-chevron" class="transition-transform">▾</span>
            </button>
            <div id="mobile-projects-list" class="hidden flex-col pl-4">
                {projects.map((project) => (
                    <a
                        href={`/${project.id}`}
                        class={`rounded px-2 py-1 text-white transition-colors hover:bg-white/10 ${project.id === currentProject ? "font-bold" : ""}`}
                    >
                        {project.data.title}
                    </a>
                ))}
            </div>
        </div>

        {currentProjectData && (
            <>
                <div class="h-px bg-white/10" />
                <a href={`/${currentProject}`} class="rounded px-2 py-1 font-bold text-white transition-colors hover:bg-white/10">
                    {currentProjectData.data.title}
                </a>
            </>
        )}
        {links.map(([title, href]) => (
            <a class="rounded px-2 py-1 text-white transition-colors hover:bg-white/10" href={href}>
                {title}
            </a>
        ))}
    </div>
</nav>

<script>
    function init() {
        const hamburger = document.getElementById("nav-hamburger");
        const menu = document.getElementById("nav-mobile-menu");
        const projectsToggle = document.getElementById("mobile-projects-toggle");
        const projectsList = document.getElementById("mobile-projects-list");
        const chevron = document.getElementById("mobile-projects-chevron");

        if (!hamburger || !menu) return;

        hamburger.addEventListener("click", () => {
            menu.classList.toggle("hidden");
            menu.classList.toggle("flex");
        });

        projectsToggle?.addEventListener("click", () => {
            projectsList?.classList.toggle("hidden");
            projectsList?.classList.toggle("flex");
            if (chevron) chevron.style.transform = projectsList?.classList.contains("flex") ? "rotate(180deg)" : "";
        });
    }

    document.addEventListener("astro:after-swap", init);
    init();
</script>