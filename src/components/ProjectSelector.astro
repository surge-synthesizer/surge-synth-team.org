---
import { getCollection } from "astro:content";

interface Props {
    currentProject?: string | null;
}

const { currentProject = null } = Astro.props;
const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
---

<li class="relative" id="desktop-projects-dropdown">
    <button
        type="button"
        id="desktop-projects-toggle"
        class="cursor-pointer rounded px-2 py-1 text-white transition-colors">
        Projects
    </button>
    <ul
        id="desktop-projects-list"
        class="invisible absolute top-full left-0 z-10 min-w-[180px] rounded border border-white/10 bg-black py-2 shadow-lg dark:bg-neutral-900">
        {
            projects.map((project) => (
                <li>
                    <a
                        href={`/${project.id}`}
                        class={`block px-4 py-2 text-white transition-colors hover:bg-white hover:text-black ${project.id === currentProject ? "font-bold" : ""}`}>
                        {project.data.title}
                    </a>
                </li>
            ))
        }
    </ul>
</li>
